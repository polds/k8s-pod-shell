{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "required": [
    "image",
    "target",
    "service"
  ],
  "properties": {
    "image": {
      "type": "object",
      "required": [
        "repository",
        "pullPolicy"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string"
        }
      }
    },
    "target": {
      "type": "object",
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "Deployment",
            "StatefulSet",
            "DaemonSet"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string"
        }
      }
    }
  }
}